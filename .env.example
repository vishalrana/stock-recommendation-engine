# ===========================================
# Stock Recommendation Engine — Environment
# ===========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ===========================================

# Supabase Project URL
# Found in: Supabase Dashboard > Settings > API > Project URL
SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Service Role Key (SECRET — used by jobs/ only)
# Found in: Supabase Dashboard > Settings > API > service_role key
# This key bypasses RLS and can write to the database.
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Supabase Anonymous Key (PUBLIC — used by frontend)
# Found in: Supabase Dashboard > Settings > API > anon public key
# This key can only read via RLS policies.
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# HMM Regime detection toggle (default off for gradual rollout)
USE_HMM=false

# Tiingo API Key for Intraday Monitor price updates
TIINGO_API_KEY=your-tiingo-token-here
